{
  "name": "ultramemory",
  "version": "1.1.0-beta.10",
  "private": true,
  "description": "OpenClaw enhanced LanceDB memory plugin with hybrid retrieval (Vector + BM25), cross-encoder rerank, multi-scope isolation, long-context chunking, and management CLI",
  "workspaces": ["packages/*"],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "lancedb",
    "vector-search",
    "bm25",
    "hybrid-retrieval",
    "rerank",
    "ai-memory",
    "long-term-memory",
    "chunking",
    "long-context"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CortexReach/memory-lancedb-pro.git"
  },
  "author": "win4r",
  "license": "MIT",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck --filter=@ultramemory/server --filter=@ultramemory/openclaw"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.9.3"
  }
}
