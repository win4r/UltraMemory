{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "typeRoots": ["src/typestubs", "node_modules/@types"]
  },
  "include": ["src/**/*.ts", "src/typestubs/**/*.d.ts"],
  "exclude": ["node_modules"]
}
