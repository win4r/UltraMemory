{
  "name": "@ultramemory/openclaw",
  "version": "0.1.0",
  "type": "module",
  "main": "index.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@ultramemory/core": "workspace:*",
    "@ultramemory/server": "workspace:*",
    "@sinclair/typebox": "0.34.48"
  },
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit 2>&1 | grep -v '../core/src/' | grep 'error TS' && exit 1 || exit 0"
  }
}
